# ==================== ADHD Coach - Environment Configuration ====================
# Copy this file to .env and fill in your values
# cp .env.example .env

# ==================== API Configuration ====================
API_HOST=0.0.0.0
API_PORT=8000
MAX_CONCURRENT_AI_REQUESTS=4

# ==================== AI / LLM Configuration ====================
# Primary: Groq API (for production / cloud deployment)
GROQ_API_KEY=

# Fallback: Local Ollama (for development / offline)
OLLAMA_URL=http://localhost:11434/api/generate

# ==================== Database Configuration ====================
# Production: Neon PostgreSQL or any PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/adhd_coach

# For local development, comment out DATABASE_URL above and uncomment:
# DATABASE_URL=sqlite:///./adhd_coach.db

# ==================== JWT Authentication ====================
# Generate a secure random key: python -c "import os; print(os.urandom(32).hex())"
JWT_SECRET_KEY=change-this-to-a-random-secret-key
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ==================== Rate Limiting ====================
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=30

# ==================== Frontend Configuration ====================
# Vercel deployment URL (for CORS)
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# ==================== Monitoring & Logging ====================
LOG_LEVEL=INFO
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ==================== Feature Flags ====================
ENABLE_RAG=true
ENABLE_GAMIFICATION=true
ENABLE_FACT_EXTRACTION=true
